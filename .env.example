# Скопируй в .env и укажи адрес своего сервера PocketBase.
# Без него приложение работает в демо-режиме на localStorage этого браузера.
#
# PocketBase можно поднять на РФ-VPS (Selectel/Timeweb/…), поэтому
# хранение персональных данных совместимо с 152-ФЗ. См. pocketbase/README.md

VITE_PB_URL=

# Адрес ws-сервиса «Комнаты авторов» (realtime/server.js), напр. wss://rt.example.ru
# Без него «Комната» работает в демо-режиме (локальная симуляция эстафеты). См. realtime/README.md
VITE_RT_URL=
